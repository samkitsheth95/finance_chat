# Zerodha Kite Connect
# Get these from https://developers.kite.trade
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Generated daily via: python scripts/refresh_token.py
KITE_ACCESS_TOKEN=

# Set to false if behind a corporate proxy with SSL inspection
KITE_SSL_VERIFY=true


# No API keys needed for Layer 5 (News) — uses RSS feeds + Google News (free)
